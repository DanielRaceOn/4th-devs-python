# 03_01_observability — environment variables
#
# Copy this file to .env and fill in the values.
# This file overrides the root .env for module-specific settings.
#
# Langfuse tracing (optional — server runs without these, tracing is disabled)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # Default: Langfuse Cloud

# HTTP server port
PORT=3010
